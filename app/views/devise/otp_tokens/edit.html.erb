<div class="card card-border">
  <div class="card-body items-center gap-8">
    <h2 class="card-title">Enable authenticator app</h2>
    <p class="text-sm text-center">Scan the QR code with your authenticator app, then enter the 6-digit code it shows.</p>

    <div class="flex justify-center bg-base-200 p-4 rounded-lg [&_svg]:size-48">
      <%= otp_authenticator_token_image(resource) %>
    </div>

    <div class="text-sm space-y-1 w-full">
      <div class="font-semibold">Can't scan? Enter this key manually:</div>
      <code class="block bg-base-200 rounded px-2 py-1 text-xs break-all"><%= resource.otp_auth_secret %></code>
    </div>

    <%= form_with(url: [resource_name, :otp_token], method: :put, class: "w-full space-y-4") do |f| %>
      <div>
        <%= f.label :confirmation_code, "Confirmation code", class: "block text-sm font-medium" %>
        <%= f.text_field :confirmation_code,
              autocomplete: "one-time-code",
              inputmode: "numeric",
              autofocus: true,
              maxlength: 6,
              class: "input w-full outline-none tracking-widest text-center font-mono" %>
      </div>

      <%= f.submit "Confirm and enable", class: "btn btn-primary text-white" %>
    <% end %>
  </div>
</div>
