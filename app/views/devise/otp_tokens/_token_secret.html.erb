<div class="flex justify-center bg-base-200 p-4 rounded-lg [&_svg]:size-48">
  <%= otp_authenticator_token_image(resource) %>
</div>

<div class="text-sm space-y-1 w-full">
  <div class="font-semibold">Setup key:</div>
  <code class="block bg-base-200 rounded px-2 py-1 text-xs break-all"><%= resource.otp_auth_secret %></code>
</div>

<div class="flex flex-col items-center gap-2">
  <%= button_to "Reset secret",
        reset_otp_token_path_for(resource),
        method: :post,
        class: "btn btn-error text-white",
        data: { turbo_method: :post } %>
  <p class="text-xs opacity-70 text-center">
    Resetting forces you to re-scan on your authenticator.
    <strong>This also invalidates your recovery codes.</strong>
  </p>
</div>

<% if recovery_enabled? %>
  <div class="divider my-0 w-full"></div>
  <h3 class="font-semibold">Recovery codes</h3>
  <p class="text-sm text-center">Save these somewhere safe. Each can be used once if you lose access to your device.</p>
  <div class="flex gap-2">
    <%= link_to "View codes", recovery_otp_token_for(resource_name), class: "btn btn-outline" %>
    <%= link_to "Download", recovery_otp_token_for(resource_name, format: :text), class: "btn btn-outline" %>
  </div>
<% end %>
